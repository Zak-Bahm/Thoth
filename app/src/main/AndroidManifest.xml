<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Required for ZIM archive downloads — app remains offline after setup -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!-- Foreground service for downloads and model loading -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".ThothApplication"
        android:allowBackup="true"
        android:label="Thoth"
        tools:replace="android:label"
        android:supportsRtl="true"
        android:theme="@style/Theme.Thoth">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Thoth">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <service
            android:name=".knowledge.ZimDownloadForegroundService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />
        <service
            android:name=".inference.ModelDownloadForegroundService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

        <!-- Debug/test harness: drive queries over adb. Exported so `am broadcast` from
             the shell can reach it. Debug tooling only. -->
        <receiver
            android:name=".debug.DebugReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.bahm.thoth.DEBUG_QUERY" />
                <action android:name="com.bahm.thoth.DEBUG_QUERY_QUICK" />
                <action android:name="com.bahm.thoth.DEBUG_SEARCH" />
                <action android:name="com.bahm.thoth.DEBUG_LOAD" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
